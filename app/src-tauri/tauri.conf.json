{
  "productName": "SiYuan",
  "identifier": "org.b3log.siyuan",
  "version": "3.6.1",
  "build": {
    "frontendDist": "../stage/build/tauri",
    "beforeBuildCommand": "pnpm run build:tauri"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SiYuan",
        "width": 1280,
        "height": 800,
        "minWidth": 493,
        "minHeight": 376,
        "decorations": false,
        "visible": false,
        "dragDropEnabled": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "kernel/SiYuan-Kernel"
    ],
    "targets": "all"
  }
}
